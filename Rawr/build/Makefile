	$(MAKE) $(MAKESILENT) -f CMakeFiles/rawr.dir/build.make CMakeFiles/rawr.dir/utils/logging.cpp.o
	$(MAKE) $(MAKESILENT) -f CMakeFiles/rawr_simple.dir/build.make CMakeFiles/rawr_simple.dir/utils/logging.cpp.o
.PHONY : utils/logging.cpp.o

utils/logging.i: utils/logging.cpp.i
.PHONY : utils/logging.i

# target to preprocess a source file
utils/logging.cpp.i:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/rawr.dir/build.make CMakeFiles/rawr.dir/utils/logging.cpp.i
	$(MAKE) $(MAKESILENT) -f CMakeFiles/rawr_simple.dir/build.make CMakeFiles/rawr_simple.dir/utils/logging.cpp.i
.PHONY : utils/logging.cpp.i

utils/logging.s: utils/logging.cpp.s
.PHONY : utils/logging.s

# target to generate assembly for a file
utils/logging.cpp.s:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/rawr.dir/build.make CMakeFiles/rawr.dir/utils/logging.cpp.s
	$(MAKE) $(MAKESILENT) -f CMakeFiles/rawr_simple.dir/build.make CMakeFiles/rawr_simple.dir/utils/logging.cpp.s
.PHONY : utils/logging.cpp.s

